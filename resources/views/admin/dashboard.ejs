<% page = 'dashboard' %>

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard - SymbiEat</title>
    <link rel="icon" href="/img/symbi.ico" type="image/x-icon" />
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/notification.css" />
    <script src="/resources-js/notification.js" defer></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=Jost:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Sora", sans-serif;
        color: #1a1a1a;
        background: linear-gradient(135deg, #f5f7fc 0%, #f0f3f8 100%);
        min-height: 100vh;
      }

      h1, h2, h3, h4, h5, h6 {
        font-family: "Jost", sans-serif;
        font-weight: 600;
        letter-spacing: -0.3px;
      }

      /* ==================== SIDEBAR ==================== */
      .admin-sidebar {
        background: linear-gradient(180deg, #0f1419 0%, #1a202c 100%);
        min-height: 100vh;
        box-shadow: 4px 0 20px rgba(0, 0, 0, 0.15);
        position: sticky;
        top: 0;
      }

      .admin-sidebar .p-6 {
        padding: 24px;
      }

      .logo-container {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 32px;
        padding-bottom: 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      }

      .logo-icon {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        padding: 10px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3);
      }

      .logo-text h1 {
        color: #ffffff;
        font-size: 18px;
        margin-bottom: 2px;
      }

      .logo-text p {
        color: #9ca3af;
        font-size: 12px;
        font-weight: 500;
      }

      /* User Profile Card */
      .admin-user-card {
        background: rgba(79, 70, 229, 0.08);
        border: 1px solid rgba(79, 70, 229, 0.2);
        border-radius: 12px;
        padding: 14px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
      }

      .admin-user-card:hover {
        background: rgba(79, 70, 229, 0.12);
        border-color: rgba(79, 70, 229, 0.4);
      }

      .user-avatar {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        color: white;
        border-radius: 8px;
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 14px;
        flex-shrink: 0;
      }

      .user-info p:first-child {
        color: #f3f4f6;
        font-weight: 600;
        font-size: 13px;
        margin-bottom: 2px;
      }

      .user-info p:last-child {
        color: #9ca3af;
        font-size: 11px;
      }

      /* Navigation */
      nav.nav-menu {
        margin-bottom: 24px;
      }

      .admin-nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 14px;
        color: #9ca3af;
        border-radius: 8px;
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        transition: all 0.3s ease;
        border-left: 3px solid transparent;
        margin-bottom: 4px;
        cursor: pointer;
      }

      .admin-nav-item svg {
        width: 18px;
        height: 18px;
        flex-shrink: 0;
      }

      .admin-nav-item:hover {
        background: rgba(79, 70, 229, 0.1);
        color: #e0e7ff;
        border-left-color: #6366f1;
      }

      .admin-nav-item.active {
        background: rgba(79, 70, 229, 0.15);
        color: #818cf8;
        border-left-color: #6366f1;
      }

      .nav-divider {
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        margin: 12px 0;
      }

      /* ==================== MAIN CONTENT ==================== */
      .admin-main-content {
        min-height: 100vh;
        padding: 32px;
        flex: 1;
      }

      /* Header Section */
      .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 32px;
        animation: slideInTop 0.5s ease-out;
      }

      .header-left h2 {
        font-size: 28px;
        color: #0f1419;
        margin-bottom: 8px;
      }

      .header-left p {
        font-size: 14px;
        color: #6b7280;
      }

      .header-right {
        display: flex;
        align-items: center;
        gap: 16px;
      }

      .status-badge {
        background: linear-gradient(135deg, rgba(34, 197, 94, 0.1) 0%, rgba(34, 197, 94, 0.05) 100%);
        border: 1px solid rgba(34, 197, 94, 0.3);
        color: #22c55e;
        padding: 8px 12px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .status-indicator {
        width: 6px;
        height: 6px;
        background: #22c55e;
        border-radius: 50%;
        animation: pulse 2s infinite;
      }

      .refresh-btn {
        background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
        color: white;
        border: none;
        padding: 10px 16px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
      }

      .refresh-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(99, 102, 241, 0.4);
      }

      .refresh-btn svg {
        width: 16px;
        height: 16px;
      }

      /* Statistics Cards */
      .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
        margin-bottom: 32px;
      }

      .admin-card {
        background: white;
        border-radius: 12px;
        padding: 20px;
        border: 1px solid #e5e7eb;
        transition: all 0.3s ease;
        animation: slideInUp 0.5s ease-out;
      }

      .admin-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 24px rgba(0, 0, 0, 0.08);
        border-color: #f0f0f0;
      }

      .card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 12px;
      }

      .card-title {
        font-size: 13px;
        color: #6b7280;
        font-weight: 500;
        letter-spacing: 0.3px;
        text-transform: uppercase;
      }

      .card-icon {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }

      .card-value {
        font-size: 28px;
        font-weight: 700;
        color: #1a1a1a;
        margin-bottom: 4px;
      }

      .card-change {
        font-size: 12px;
        color: #9ca3af;
      }

      .icon-blue { background: linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, rgba(59, 130, 246, 0.05) 100%); color: #3b82f6; }
      .icon-green { background: linear-gradient(135deg, rgba(34, 197, 94, 0.1) 0%, rgba(34, 197, 94, 0.05) 100%); color: #22c55e; }
      .icon-orange { background: linear-gradient(135deg, rgba(251, 146, 60, 0.1) 0%, rgba(251, 146, 60, 0.05) 100%); color: #fb923c; }
      .icon-purple { background: linear-gradient(135deg, rgba(168, 85, 247, 0.1) 0%, rgba(168, 85, 247, 0.05) 100%); color: #a855f7; }
      .icon-indigo { background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(99, 102, 241, 0.05) 100%); color: #6366f1; }

      /* Analytics Section */
      .analytics-section {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 32px;
        animation: slideInUp 0.5s ease-out;
        animation-delay: 0.2s;
      }

      .chart-card {
        background: white;
        border-radius: 12px;
        padding: 24px;
        border: 1px solid #e5e7eb;
      }

      .chart-title {
        font-size: 16px;
        font-weight: 600;
        color: #1a1a1a;
        margin-bottom: 20px;
      }

      .chart-container {
        height: 280px;
        background: #f9fafb;
        border-radius: 8px;
        padding: 12px;
      }

      /* Kitchen Status */
      .kitchen-status {
        background: linear-gradient(135deg, #0f1419 0%, #1a202c 100%);
        border-radius: 12px;
        padding: 24px;
        color: white;
        margin-bottom: 32px;
        animation: slideInUp 0.5s ease-out;
        animation-delay: 0.3s;
      }

      .kitchen-status h3 {
        color: #fff;
        font-size: 18px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .kitchen-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
      }

      .kitchen-item {
        background: rgba(79, 70, 229, 0.08);
        border: 1px solid rgba(79, 70, 229, 0.2);
        border-radius: 8px;
        padding: 16px;
        transition: all 0.3s ease;
      }

      .kitchen-item:hover {
        background: rgba(79, 70, 229, 0.12);
        border-color: rgba(79, 70, 229, 0.4);
      }

      .kitchen-label {
        font-size: 12px;
        color: #9ca3af;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.3px;
      }

      .kitchen-value {
        font-size: 24px;
        font-weight: 700;
        color: #fff;
      }

      /* Orders Table */
      .orders-section {
        background: white;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        animation: slideInUp 0.5s ease-out;
        animation-delay: 0.4s;
      }

      .orders-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 24px;
        border-bottom: 1px solid #e5e7eb;
      }

      .orders-title {
        font-size: 16px;
        font-weight: 600;
        color: #1a1a1a;
      }

      .filters-group {
        display: flex;
        gap: 12px;
        align-items: center;
      }

      .filter-select, .search-input {
        padding: 8px 12px;
        border: 1px solid #d1d5db;
        border-radius: 6px;
        font-size: 13px;
        font-family: "Sora", sans-serif;
        background: white;
        color: #1a1a1a;
        transition: all 0.3s ease;
      }

      .filter-select:focus, .search-input:focus {
        outline: none;
        border-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
      }

      .search-input {
        width: 200px;
      }

      .admin-table {
        width: 100%;
        border-collapse: collapse;
      }

      .admin-table thead {
        background: #f9fafb;
        border-bottom: 1px solid #e5e7eb;
      }

      .admin-table th {
        padding: 16px 24px;
        text-align: left;
        font-size: 12px;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      .admin-table td {
        padding: 16px 24px;
        border-bottom: 1px solid #f3f4f6;
        font-size: 13px;
      }

      .admin-table tbody tr {
        transition: all 0.3s ease;
      }

      .admin-table tbody tr:hover {
        background: #f9fafb;
      }

      .token-badge {
        background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
        color: white;
        width: 32px;
        height: 32px;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 12px;
      }

      .order-id {
        background: #f3f4f6;
        color: #4b5563;
        padding: 4px 8px;
        border-radius: 4px;
        font-family: 'Courier New', monospace;
        font-size: 12px;
      }

      .customer-avatar {
        width: 32px;
        height: 32px;
        border-radius: 6px;
        background: #e5e7eb;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        color: #6b7280;
        font-size: 12px;
        margin-right: 8px;
      }

      .customer-info {
        display: inline-block;
      }

      .customer-name {
        font-weight: 600;
        color: #1a1a1a;
        display: block;
      }

      .customer-email {
        color: #9ca3af;
        font-size: 12px;
      }

      .status-select {
        width: 100%;
        padding: 8px 10px;
        border: 1px solid #d1d5db;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        background: white;
        transition: all 0.3s ease;
      }

      .status-select:focus {
        outline: none;
        border-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
      }

      .action-buttons {
        display: flex;
        gap: 8px;
      }

      .action-btn {
        width: 32px;
        height: 32px;
        border: none;
        border-radius: 6px;
        background: #f3f4f6;
        color: #6b7280;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        flex-shrink: 0;
      }

      .action-btn:hover {
        background: #e5e7eb;
        color: #1a1a1a;
      }

      .action-btn svg {
        width: 16px;
        height: 16px;
      }

      /* Animations */
      @keyframes slideInTop {
        from {
          opacity: 0;
          transform: translateY(-20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @keyframes slideInUp {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
      }

      /* Responsive */
      @media (max-width: 1024px) {
        .analytics-section {
          grid-template-columns: 1fr;
        }

        .admin-main-content {
          padding: 20px;
        }
      }

      @media (max-width: 768px) {
        .admin-sidebar {
          width: 100%;
          min-height: auto;
        }

        .stats-grid {
          grid-template-columns: 1fr;
        }

        .header-right {
          flex-direction: column;
          width: 100%;
        }

        .filters-group {
          flex-direction: column;
        }

        .search-input {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <div class="flex">
      <!-- Admin Sidebar -->
      <aside class="admin-sidebar w-64">
        <div class="p-6">
          <!-- Logo -->
          <div class="logo-container">
            <div class="logo-icon">
              <img src="/img/symbi.ico" alt="SymbiEat Logo" class="h-6 w-6" />
            </div>
            <div class="logo-text">
              <h1>SymbiEat</h1>
              <p>Admin Panel</p>
            </div>
          </div>
          
          <!-- Admin Info -->
          <div class="admin-user-card">
            <div class="user-avatar">
              <%= user ? user.name.charAt(0).toUpperCase() : 'A' %>
            </div>
            <div class="user-info">
              <p><%= user ? user.name : 'Admin' %></p>
              <p>Administrator</p>
            </div>
          </div>
          
          <!-- Navigation -->
          <nav class="nav-menu">
            <a href="/admin/orders" class="admin-nav-item <%= typeof page !== 'undefined' && page === 'orders' ? 'active' : '' %>">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
              </svg>
              <span>Orders</span>
            </a>
            
            <a href="/admin/dashboard" class="admin-nav-item <%= typeof page !== 'undefined' && page === 'dashboard' ? 'active' : '' %>">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
              </svg>
              <span>Dashboard</span>
            </a>
            
            <div class="nav-divider"></div>
            
            <a href="/" class="admin-nav-item">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
              </svg>
              <span>View Site</span>
            </a>
            
            <form action="/logout" method="POST" style="display: block;">
              <button type="submit" class="admin-nav-item" style="width: 100%; text-align: left; background: none; border: none; padding-left: 14px;">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                </svg>
                <span>Logout</span>
              </button>
            </form>
          </nav>
        </div>
      </aside>
      
      <!-- Main Content -->
      <main class="admin-main-content flex-1">
        <!-- Header -->
        <div class="dashboard-header">
          <div class="header-left">
            <h2>Dashboard</h2>
            <p>Real-time order management & analytics</p>
          </div>
          <div class="header-right">
            <div class="status-badge">
              <div class="status-indicator"></div>
              <span>LIVE</span>
            </div>
            <button onclick="location.reload()" class="refresh-btn">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
              </svg>
              Refresh
            </button>
          </div>
        </div>

        <!-- Statistics Cards -->
        <div class="stats-grid">
          <div class="admin-card">
            <div class="card-header">
              <div class="card-title">Total Orders</div>
              <div class="card-icon icon-blue">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                </svg>
              </div>
            </div>
            <div class="card-value"><%= stats.totalOrders %></div>
            <div class="card-change">↑ 12% from last week</div>
          </div>

          <div class="admin-card">
            <div class="card-header">
              <div class="card-title">Total Revenue</div>
              <div class="card-icon icon-green">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
            </div>
            <div class="card-value">₹<%= stats.totalRevenue.toFixed(0) %></div>
            <div class="card-change">↑ 8% from last month</div>
          </div>

          <div class="admin-card">
            <div class="card-header">
              <div class="card-title">Pending Orders</div>
              <div class="card-icon icon-orange">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
            </div>
            <div class="card-value"><%= stats.pendingOrders %></div>
            <div class="card-change">Awaiting confirmation</div>
          </div>

          <div class="admin-card">
            <div class="card-header">
              <div class="card-title">Preparing</div>
              <div class="card-icon icon-purple">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                </svg>
              </div>
            </div>
            <div class="card-value"><%= stats.preparedOrders %></div>
            <div class="card-change">In the kitchen</div>
          </div>

          <div class="admin-card">
            <div class="card-header">
              <div class="card-title">Today's Revenue</div>
              <div class="card-icon icon-indigo">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
            </div>
            <div class="card-value">₹<%= stats.todayRevenue.toFixed(0) %></div>
            <div class="card-change">↑ 15% today</div>
          </div>
        </div>

        <!-- Analytics Section -->
        <div class="analytics-section">
          <div class="chart-card">
            <div class="chart-title">Revenue Analytics (Last 7 Days)</div>
            <div class="chart-container">
              <canvas id="revenueChart"></canvas>
            </div>
          </div>

          <div class="chart-card">
            <div class="chart-title">Quick Stats</div>
            <div style="display: flex; flex-direction: column; gap: 16px;">
              <div>
                <div style="font-size: 12px; color: #6b7280; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.3px; font-weight: 600;">Today</div>
                <div style="font-size: 22px; font-weight: 700; color: #3b82f6;">₹<%= stats.todayRevenue.toFixed(2) %></div>
              </div>
              <div>
                <div style="font-size: 12px; color: #6b7280; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.3px; font-weight: 600;">This Week</div>
                <div style="font-size: 22px; font-weight: 700; color: #22c55e;">₹<%= stats.weeklyRevenue.toFixed(2) %></div>
              </div>
              <div>
                <div style="font-size: 12px; color: #6b7280; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.3px; font-weight: 600;">This Month</div>
                <div style="font-size: 22px; font-weight: 700; color: #a855f7;">₹<%= stats.monthlyRevenue.toFixed(2) %></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Kitchen Status -->
        <div class="kitchen-status">
          <h3>🍳 Kitchen Status</h3>
          <div class="kitchen-grid">
            <div class="kitchen-item">
              <div class="kitchen-label">Average Order Value</div>
              <div class="kitchen-value">₹<%= stats.avgOrderValue.toFixed(0) %></div>
            </div>
            <div class="kitchen-item">
              <div class="kitchen-label">Orders in Queue</div>
              <div class="kitchen-value"><%= stats.pendingOrders + stats.confirmedOrders + stats.preparedOrders %></div>
            </div>
            <div class="kitchen-item">
              <div class="kitchen-label">Completed Today</div>
              <div class="kitchen-value"><%= stats.completedOrders %></div>
            </div>
          </div>
        </div>

        <!-- Orders Section -->
        <div class="orders-section">
          <div class="orders-header">
            <div class="orders-title">All Orders (<%= orders.length %>)</div>
            <div class="filters-group">
              <select id="statusFilter" class="filter-select">
                <option value="">All Orders</option>
                <option value="placed">Placed</option>
                <option value="confirmed">Confirmed</option>
                <option value="prepared">Prepared</option>
                <option value="completed">Completed</option>
              </select>
              <input type="text" id="searchOrder" placeholder="Search by order ID or customer..." class="search-input">
            </div>
          </div>

          <!-- Orders Table -->
          <div style="overflow-x: auto;">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Token</th>
                  <th>Order ID</th>
                  <th>Customer</th>
                  <th>Items</th>
                  <th>Total</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>

              <tbody>
                <% if (orders && orders.length) { %>
                  <% 
                    const sortedOrders = [...orders].sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
                    sortedOrders.forEach((order, index) => { 
                      const tokenNumber = sortedOrders.length - index;
                  %>
                    <tr>
                      <td>
                        <span class="token-badge"><%= tokenNumber %></span>
                      </td>

                      <td>
                        <span class="order-id"><%= order._id.toString().slice(-6) %></span>
                      </td>

                      <td>
                        <span class="customer-avatar"><%= order.customerId && order.customerId.name ? order.customerId.name.charAt(0).toUpperCase() : '?' %></span>
                        <div class="customer-info">
                          <span class="customer-name"><%= order.customerId && order.customerId.name ? order.customerId.name : "Unknown" %></span>
                          <% if (order.customerId && order.customerId.email) { %>
                            <span class="customer-email"><%= order.customerId.email %></span>
                          <% } %>
                        </div>
                      </td>

                      <td>
                        <% if (order.items && order.items.length) { %>
                          <%= order.items.length %> item<%= order.items.length > 1 ? 's' : '' %>
                        <% } else { %>
                          <span style="color: #9ca3af;">No items</span>
                        <% } %>
                      </td>

                      <td style="font-weight: 600; color: #1a1a1a;">₹<%= order.totalPrice || 0 %></td>

                      <td>
                        <div class="action-buttons">
                          <% if (order.status !== 'completed') { %>
                            <button onclick="markAsCompleted('<%= order._id %>')" class="action-btn" title="Mark as Completed">
                              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                              </svg>
                            </button>
                          <% } %>
                          <button onclick="deleteOrder('<%= order._id %>')" class="action-btn" title="Delete Order">
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                            </svg>
                          </button>
                        </div>
                      </td>
                    </tr>
                  <% }); %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </main>
    </div>

    <!-- Load Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <!-- Load Axios -->
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    
    <script>
      // Revenue Chart
      const chartCtx = document.getElementById('revenueChart').getContext('2d');
      const revenueChart = new Chart(chartCtx, {
        type: 'line',
        data: {
          labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
          datasets: [{
            label: 'Revenue',
            data: [1200, 1800, 2200, 1900, 2800, 3200, 2900],
            borderColor: '#6366f1',
            backgroundColor: 'rgba(99, 102, 241, 0.1)',
            borderWidth: 2,
            tension: 0.4,
            fill: true
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: false
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              ticks: {
                callback: function(value) {
                  return '₹' + value;
                }
              }
            }
          }
        }
      });

      // Update Order Status
      function updateOrderStatus(selectElement) {
        const orderId = selectElement.dataset.id;
        const newStatus = selectElement.value;
        
        axios.put(`/admin/orders/${orderId}/status`, { status: newStatus })
          .then(response => {
            console.log('Order status updated successfully');
            // Show success notification
            showNotification('Order status updated successfully', 'success');
          })
          .catch(error => {
            console.error('Error updating order status:', error);
            // Show error notification
            showNotification('Error updating order status', 'error');
          });
      }

      // Mark as Completed
      function markAsCompleted(orderId) {
        axios.put(`/admin/orders/${orderId}/status`, { status: 'completed' })
          .then(response => {
            console.log('Order marked as completed');
            location.reload();
          })
          .catch(error => {
            console.error('Error marking order as completed:', error);
          });
      }

      // Delete Order
      function deleteOrder(orderId) {
        if (confirm('Are you sure you want to delete this order?')) {
          axios.delete(`/admin/orders/${orderId}`)
            .then(response => {
              console.log('Order deleted successfully');
              location.reload();
            })
            .catch(error => {
              console.error('Error deleting order:', error);
            });
        }
      }

      // Show notification function
      function showNotification(message, type) {
        // Create notification element
        const notification = document.createElement('div');
        notification.className = `notification ${type}`;
        notification.textContent = message;
        
        // Add to page
        document.body.appendChild(notification);
        
        // Remove after 3 seconds
        setTimeout(() => {
          notification.remove();
        }, 3000);
      }
    </script>
  </body>
</html>
