</style>

<!-- Current user data for Socket.IO -->
<script id="current-user" type="application/json">
  <%= JSON.stringify({ id: user._id, name: user.name, role: 'customer' }) %>
</script>

<!-- Store order ID for tracking -->
<% if (typeof orderId !== 'undefined' && orderId) { %>
<script>
  localStorage.setItem('lastOrderId', '<%= orderId %>');
  localStorage.setItem('lastOrderNumber', '<%= orderNumber %>');
</script>
<% } %>

<!-- Socket.IO client -->
<script src="/socket.io/socket.io.js"></script>

<script>
// Order Tracking Modal Functionality
class OrderTrackingModal {
  constructor() {
    this.modal = document.getElementById('orderTrackingModal');
    this.closeBtn = document.getElementById('closeTrackingModal');
    this.trackBtn = document.getElementById('trackOrderBtn');
    this.currentOrderId = null;
    this.init();
  }

  init() {
    if (this.trackBtn) {
      this.trackBtn.addEventListener('click', () => this.openModal());
    }
    
    if (this.closeBtn) {
      this.closeBtn.addEventListener('click', () => this.closeModal());
    }

    // Close modal when clicking outside
    this.modal.addEventListener('click', (e) => {
      if (e.target === this.modal) {
        this.closeModal();
      }
    });

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !this.modal.classList.contains('hidden')) {
        this.closeModal();
      }
    });
  }

  async openModal(orderId = null) {
    this.currentOrderId = orderId || localStorage.getItem('lastOrderId');
    
    if (!this.currentOrderId) {
      alert('No order found to track. Please place an order first.');
      return;
    }

    this.modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';

    // Animate modal entrance
    gsap.fromTo(this.modal.querySelector('.bg-white'), 
      { scale: 0.8, opacity: 0 },
      { scale: 1, opacity: 1, duration: 0.3, ease: "back.out(1.7)" }
    );

    // Load order data
    await this.loadOrderData();
  }

  closeModal() {
    gsap.to(this.modal.querySelector('.bg-white'), {
      scale: 0.8, 
      opacity: 0, 
      duration: 0.2,
      onComplete: () => {
        this.modal.classList.add('hidden');
        document.body.style.overflow = 'auto';
      }
    });
  }

  async loadOrderData() {
    const loadingDiv = document.getElementById('trackingLoading');
    const detailsDiv = document.getElementById('orderDetails');
    
    loadingDiv.classList.remove('hidden');
    detailsDiv.classList.add('hidden');

    try {
      const response = await axios.get(`/api/orders/${this.currentOrderId}`);
      const order = response.data;

      this.populateOrderData(order);
      
      loadingDiv.classList.add('hidden');
      detailsDiv.classList.remove('hidden');

      // Animate content entrance
      gsap.fromTo('#orderDetails > *', 
        { y: 20, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.5, stagger: 0.1, ease: "power2.out" }
      );

    } catch (error) {
      console.error('Error loading order data:', error);
      loadingDiv.innerHTML = `
        <div class="text-center py-8">
          <div class="text-red-500 mb-4">
            <svg class="w-12 h-12 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <p class="text-gray-600">Failed to load order details. Please try again.</p>
          <button onclick="location.reload()" class="mt-4 px-4 py-2 bg-[#1D3557] text-white rounded-lg hover:bg-[#2a4a73] transition-colors">
            Retry
          </button>
        </div>
      `;
    }
  }

  populateOrderData(order) {
    // Update order header
    document.getElementById('orderNumber').textContent = `Order #${order.orderNumber}`;

    // Update status icon and colors
    this.updateStatusIcon(order.status);

    // Update current status
    document.getElementById('currentStatus').textContent = this.formatStatus(order.status);
    document.getElementById('statusDescription').textContent = this.getStatusDescription(order.status);

    // Update progress bar
    const progress = this.getProgressPercentage(order.status);
    document.getElementById('progressBar').style.width = `${progress}%`;

    // Update estimated time
    if (order.estimatedDeliveryTime) {
      const now = new Date();
      const delivery = new Date(order.estimatedDeliveryTime);
      const diffMinutes = Math.ceil((delivery - now) / (1000 * 60));
      
      if (diffMinutes > 0) {
        document.getElementById('estimatedTime').textContent = `Ready in ${diffMinutes} mins`;
      } else {
        document.getElementById('estimatedTime').textContent = 'Ready soon!';
      }
    }

    // Update total
    document.getElementById('totalAmount').textContent = `₹${order.total.toFixed(2)}`;
  }

  updateStatusIcon(status) {
    const iconContainer = document.getElementById('statusIcon');
    const statusConfig = {
      'placed': { icon: '⏳', bg: 'bg-yellow-500' },
      'confirmed': { icon: '✅', bg: 'bg-blue-500' },
      'preparing': { icon: '👨‍🍳', bg: 'bg-purple-500' },
      'ready': { icon: '🎉', bg: 'bg-green-500' },
      'completed': { icon: '🚀', bg: 'bg-green-600' }
    };

    const config = statusConfig[status] || statusConfig['placed'];
    iconContainer.className = `w-16 h-16 mx-auto rounded-full flex items-center justify-center text-white text-2xl animate-pulse ${config.bg}`;
    iconContainer.textContent = config.icon;
  }

  getStatusDescription(status) {
    const descriptions = {
      'placed': 'Your order has been received',
      'confirmed': 'Restaurant has confirmed your order',
      'preparing': 'Your delicious food is being prepared',
      'ready': 'Your order is ready for pickup!',
      'completed': 'Order completed successfully'
    };
    return descriptions[status] || 'Order status updating...';
  }

  getProgressPercentage(status) {
    const progressMap = {
      'placed': 20,
      'confirmed': 40,
      'preparing': 60,
      'ready': 80,
      'completed': 100
    };
    return progressMap[status] || 0;
  }

  getCurrentStepIndex(status) {
    const stepMap = {
      'placed': 0,
      'confirmed': 1,
      'preparing': 2,
      'ready': 3,
      'completed': 4
    };
    return stepMap[status] || 0;
  }

  formatStatus(status) {
    return status.charAt(0).toUpperCase() + status.slice(1);
  }

  getStatusClass(status) {
    const classMap = {
      'placed': 'bg-yellow-100 text-yellow-800',
      'confirmed': 'bg-blue-100 text-blue-800',
      'preparing': 'bg-purple-100 text-purple-800',
      'ready': 'bg-green-100 text-green-800',
      'completed': 'bg-green-100 text-green-800'
    };
    return classMap[status] || 'bg-gray-100 text-gray-800';
  }
}

// Initialize modal when DOM is ready
let orderTrackingModal;
document.addEventListener('DOMContentLoaded', () => {
  orderTrackingModal = new OrderTrackingModal();
});

// Global function to open tracking modal from anywhere
window.openOrderTracking = (orderId) => {
  if (orderTrackingModal) {
    orderTrackingModal.openModal(orderId);
  }
};
</script>
<script>
class CustomerOrderTracker {
  constructor() {
    this.socket = null;
    this.currentUser = null;
    this.init();
  }

  init() {
    // Initialize Socket.IO connection
    this.socket = io();
    
    // Get current user info
    this.currentUser = JSON.parse(document.getElementById('current-user').textContent);
    
    if (this.currentUser) {
      // Join user-specific room
      this.socket.emit('join-room', {
        userId: this.currentUser.id,
        role: this.currentUser.role
      });
      
      // Set up event listeners
      this.setupEventListeners();
    }
  }

  setupEventListeners() {
    // Listen for order status updates
    this.socket.on('order-status-updated', (data) => {
      this.handleOrderStatusUpdate(data);
    });
    
    // Connection status
    this.socket.on('connect', () => {
      console.log('🔌 Connected to real-time server');
      this.showNotification('Connected to real-time updates', 'success');
    });
    
    this.socket.on('disconnect', () => {
      console.log('🔌 Disconnected from real-time server');
      this.showNotification('Connection lost', 'warning');
    });
  }

  handleOrderStatusUpdate(data) {
    const { orderId, status, orderNumber } = data;
    
    // Update order status in UI
    this.updateOrderStatusUI(orderId, status);
    
    // Show notification
    const statusMessages = {
      'placed': 'Order placed - Waiting for confirmation',
      'confirmed': 'Order confirmed - Starting preparation',
      'prepared': 'Order is being prepared',
      'completed': 'Order completed successfully',
      'cancelled': 'Order has been cancelled'
    };
    
    const message = statusMessages[status] || `Order status updated to: ${status}`;
    this.showNotification(`Order #${orderNumber}: ${message}`, 'info');
  }

  updateOrderStatusUI(orderId, status) {
    // Find and update status badge
    const statusBadge = document.querySelector(`[data-order-id="${orderId}"]`);
    if (statusBadge) {
      // Remove all status classes
      statusBadge.className = 'order-status px-3 py-1 rounded-full text-sm font-semibold capitalize';
      
      // Add new status class
      statusBadge.classList.add(status);
      statusBadge.textContent = status;
      
      // Add pulse animation for update
      statusBadge.classList.add('animate-pulse');
      setTimeout(() => {
        statusBadge.classList.remove('animate-pulse');
      }, 2000);
    }
  }

  showNotification(message, type = 'info') {
    // Create notification element
    const notification = document.createElement('div');
    notification.className = 'status-update-notification';
    notification.innerHTML = `
      <div class="flex items-center">
        <div class="flex-1">
          <div class="font-semibold">Order Update</div>
          <div class="text-sm opacity-90">${message}</div>
        </div>
        <button onclick="this.parentElement.parentElement.remove()" class="ml-4 text-white hover:text-gray-200">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    `;
    
    document.body.appendChild(notification);
    
    // Animate in
    setTimeout(() => {
      notification.classList.add('show');
    }, 100);
    
    // Auto remove after 5 seconds
    setTimeout(() => {
      notification.classList.remove('show');
      setTimeout(() => {
        if (notification.parentElement) {
          notification.parentElement.removeChild(notification);
        }
      }, 300);
    }, 5000);
  }
}

// Initialize order tracker when DOM is ready
document.addEventListener('DOMContentLoaded', () => {
  new CustomerOrderTracker();
  
  // Start countdown timer if order was successful (backup trigger)
  if (window.orderSuccess === true && typeof startCountdownTimer === 'function') {
    console.log('Order success detected, starting timer from DOM ready...');
    console.log('window.preparationTime in DOM ready:', window.preparationTime);
    const prepTime = window.preparationTime || 10;
    console.log('Using preparation time in DOM ready:', prepTime, 'minutes');
    
    // Prevent multiple timer starts
    if (window.timerStarted) {
      console.log('Timer already started, skipping DOM ready trigger...');
      return;
    }
    window.timerStarted = true;
    
    setTimeout(() => {
      startCountdownTimer(prepTime);
    }, 100);
  }
  
  // Also check for data attribute as fallback
  if (document.body.dataset.orderSuccess === 'true' && typeof startCountdownTimer === 'function') {
    console.log('Data attribute detected, starting timer...');
    const prepTime = window.preparationTime || 10;
    console.log('Using preparation time in data attribute fallback:', prepTime);
    setTimeout(() => {
      startCountdownTimer(prepTime);
    }, 100);
  }
});
</script>
